VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side Anthropic API key used by /api/generate-article and /api/generate-diagram.
# Do NOT prefix with VITE_ — must never leak to the browser bundle.
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional — kie.ai API key used by the legacy scripts/excalidraw-visuals CLI.
# NOT required by /api/generate-diagram anymore (which now renders Excalidraw scenes client-side).
# KIE_AI_API_KEY=your-kie-ai-api-key
